# Personal AI bridge. Copy to .env.server; never commit the real file.
# The Supabase secret key is server-only and must never use a VITE_ prefix.
AI_BRIDGE_PORT=8787
AI_ALLOWED_ORIGINS=http://localhost:5173,https://seenyo.github.io
AI_ALLOWED_EMAILS=your-google-account@example.com
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-ANON-KEY
SUPABASE_SECRET_KEY=YOUR-SERVER-ONLY-SECRET-KEY

# Optional. Defaults are deliberately conservative.
# CODEX_MODEL=
# CODEX_REASONING_EFFORT=high
# AI_GENERATION_REPAIR_ATTEMPTS=2
