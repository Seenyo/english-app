{
  "name": "english-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:preview": "vite --mode preview",
    "dev:ai": "node --env-file-if-exists=.env.server --import tsx --watch server/index.ts",
    "dev:ai:dry-run": "ASSESSMENT_MODE=dry-run npm run dev:ai",
    "ai:start": "node --env-file-if-exists=.env.server --import tsx server/index.ts",
    "ai:start:dry-run": "ASSESSMENT_MODE=dry-run npm run ai:start",
    "ai:smoke": "node --env-file-if-exists=.env.server --import tsx server/scripts/smoke.ts",
    "dry-run:seed": "node --env-file-if-exists=.env.server --import tsx server/scripts/seed-dry-run.ts",
    "vocabulary:import": "node --env-file-if-exists=.env.server --import tsx server/scripts/import-vocabulary.ts",
    "supabase": "supabase",
    "db:migrations:list": "supabase migration list --linked",
    "db:migrations:check": "supabase db push --linked --dry-run",
    "db:migrations:push": "supabase db push --linked",
    "build": "tsc -b && vite build && node scripts/postbuild.mjs",
    "typecheck": "tsc -b",
    "test": "node --import tsx --test server/**/*.test.ts shared/**/*.test.ts scripts/*.test.mjs src/features/developer-preview/*.test.mjs src/features/vocabulary/*.test.mjs src/features/vocabulary/components/*.test.mjs",
    "validate:ai-bridge-url": "node scripts/validate-ai-bridge-url.mjs",
    "security:client-boundary": "node scripts/check-client-boundary.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.144.5",
    "@supabase/supabase-js": "^2.110.5",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "supabase": "2.109.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  }
}
